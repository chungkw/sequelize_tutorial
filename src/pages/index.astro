---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";

import { getCollection } from "astro:content";

const pages = await getCollection("tutorial");
---

<BaseLayout title="Sequelize Tutorial">
	<Header />

	<div class="container">
		<p>
			This is my tutorial on using Sequelize, originally written in
			2021-2022.
		</p>

		<p>
			<a
				href="https://github.com/chungkw/sequelize_tutorial"
				target="_blank"
				rel="noopener noreferrer"
			>
				See the GitHub Repo
			</a>
		</p>

		<p>
			<a
				href="https://github.com/chungkw"
				target="_blank"
				rel="noopener noreferrer"
			>
				Written by Kin Wai
			</a>
		</p>

		<p class="h4">Chapters:</p>

		<ul>
			{
				pages.map((page) => (
					<li class="mb-2">
						<a href={`/sequelize_tutorial/tutorial/${page.id}`}>
							{page.data.title}
						</a>
					</li>
				))
			}
		</ul>
	</div>
</BaseLayout>
